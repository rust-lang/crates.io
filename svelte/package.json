{
  "name": "crates.io-svelte",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build-storybook": "storybook build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "chromatic": "chromatic",
    "dev": "vite dev",
    "dev:docker": "API_HOST=http://backend:8888 vite dev --host 0.0.0.0",
    "dev:live": "vite dev",
    "dev:local": "API_HOST=http://127.0.0.1:8888 vite dev",
    "dev:msw": "VITE_MSW_ENABLED=true vite dev",
    "dev:staging": "API_HOST=https://staging.crates.io vite dev",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "test": "npm run test:unit -- --run",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@crates-io/api-client": "workspace:*",
    "@floating-ui/dom": "1.7.6",
    "chart.js": "4.5.1",
    "date-fns": "4.1.0",
    "highlight.js": "11.11.1",
    "pretty-bytes": "7.1.0",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@crates-io/msw": "workspace:*",
    "@eslint/compat": "2.0.5",
    "@eslint/js": "9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@poppanator/sveltekit-svg": "7.0.0",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-svelte-csf": "5.1.2",
    "@storybook/addon-vitest": "10.3.6",
    "@storybook/sveltekit": "10.3.6",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.58.0",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@types/node": "24.12.2",
    "@types/semver": "7.7.1",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "chromatic": "16.6.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prefer-let": "4.2.2",
    "eslint-plugin-storybook": "10.3.6",
    "eslint-plugin-svelte": "3.17.1",
    "globals": "17.5.0",
    "msw": "2.14.2",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "storybook": "10.3.6",
    "svelte": "5.55.5",
    "svelte-check": "4.4.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vite-bundle-analyzer": "1.3.8",
    "vitest": "4.1.5",
    "vitest-browser-svelte": "2.1.1"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}
