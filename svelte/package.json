{
  "name": "crates.io-svelte",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build-storybook": "storybook build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "chromatic": "chromatic",
    "dev": "vite dev",
    "dev:live": "vite dev",
    "dev:local": "API_HOST=http://127.0.0.1:8888 vite dev",
    "dev:msw": "VITE_MSW_ENABLED=true vite dev",
    "dev:staging": "API_HOST=https://staging.crates.io vite dev",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "test": "npm run test:unit -- --run",
    "test:unit": "vitest"
  },
  "dependencies": {
    "@crates-io/api-client": "workspace:*",
    "@floating-ui/dom": "1.7.6",
    "@fontsource/fira-mono": "5.2.7",
    "@fontsource/fira-sans": "5.2.7",
    "@pierre/diffs": "1.2.11",
    "@pierre/trees": "1.0.0-beta.4",
    "@shikijs/themes": "4.2.0",
    "chart.js": "4.5.1",
    "date-fns": "4.4.0",
    "mermaid": "11.15.0",
    "micromark": "4.0.2",
    "micromark-extension-gfm": "3.0.0",
    "pretty-bytes": "7.1.0",
    "semver": "7.8.5",
    "shiki": "4.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@crates-io/msw": "workspace:*",
    "@iconify-json/heroicons": "1.2.3",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/octicon": "1.2.28",
    "@iconify-json/simple-icons": "1.2.86",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-svelte-csf": "5.1.2",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/sveltekit": "10.4.6",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/enhanced-img": "0.11.0",
    "@sveltejs/kit": "2.66.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/node": "24.13.2",
    "@types/semver": "7.7.1",
    "@unocss/preset-icons": "66.7.2",
    "@unocss/transformer-directives": "66.7.2",
    "@unocss/vite": "66.7.2",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "chromatic": "17.5.0",
    "magic-string": "0.30.21",
    "msw": "2.14.6",
    "playwright": "1.61.0",
    "sharp": "0.35.2",
    "storybook": "10.4.6",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-bundle-analyzer": "1.3.8",
    "vitest": "4.1.9",
    "vitest-browser-svelte": "2.1.1",
    "zimmerframe": "1.1.4"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}
